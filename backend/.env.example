NODE_ENV=development
PORT=5050
MONGODB_URI=mongodb://127.0.0.1:27017/loan_tracker
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=*

# Redis Integration
REDIS_ENABLED=true
# REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1

# Background Queue Workers
QUEUE_WORKERS_ENABLED=false

# Logging Configuration
LOG_LEVEL=info

# File Storage & Uploads
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:5050
MAX_PROOF_FILE_SIZE_MB=5

